{
  "name": "checkpointX",
  "displayName": "CheckpointX - 代码检查点管理",
  "description": "在代码开发中实时记录需要上线前检查的事项，支持分支分类和团队协作",
  "version": "3.0.0",
  "publisher": "wangxb",
  "author": {
    "name": "wangxb",
    "email": "wxb0328@hotmail.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/wxb/checkpoint-vscode#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/wxb/checkpoint-vscode"
  },
  "bugs": {
    "url": "https://github.com/wxb/checkpoint-vscode/issues"
  },
  "keywords": [
    "checkpoint",
    "code review",
    "todo",
    "git",
    "branch",
    "团队协作",
    "检查点",
    "代码审查"
  ],
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "icon": "images/icon.png",
  "activationEvents": [
    "onCommand:checkpointX.addCheckpoint",
    "onView:checkpointXTree"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "checkpointX.addCheckpoint",
        "title": "添加检查点",
        "category": "CheckpointX",
        "icon": "$(add)"
      },
      {
        "command": "checkpointX.removeCheckpoint",
        "title": "移除检查点",
        "category": "CheckpointX",
        "icon": "$(trash)"
      },
      {
        "command": "checkpointX.viewCheckpoints",
        "title": "查看所有检查点",
        "category": "CheckpointX"
      },
      {
        "command": "checkpointX.refreshTree",
        "title": "刷新",
        "category": "CheckpointX",
        "icon": "$(refresh)"
      },
      {
        "command": "checkpointX.jumpToCheckpoint",
        "title": "跳转到检查点",
        "category": "CheckpointX"
      },
      {
        "command": "checkpointX.clearAll",
        "title": "清空所有检查点",
        "category": "CheckpointX",
        "icon": "$(clear-all)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "checkpointX",
          "title": "CheckpointX",
          "icon": "images/checkpoint-icon.png"
        }
      ]
    },
    "views": {
      "checkpointX": [
        {
          "id": "checkpointXTree",
          "name": "检查点列表",
          "icon": "images/checkpoint-icon.png",
          "contextualTitle": "CheckpointX"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "checkpointXTree",
        "contents": "当前没有检查点\n\n[添加检查点](command:checkpointX.addCheckpoint)\n\n使用快捷键 `Ctrl+Alt+P` (Mac: `Cmd+Ctrl+P`) 或右键菜单添加检查点"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "checkpointX.addCheckpoint",
          "group": "9_cutcopypaste@5"
        }
      ],
      "view/title": [
        {
          "command": "checkpointX.refreshTree",
          "when": "view == checkpointXTree",
          "group": "navigation"
        },
        {
          "command": "checkpointX.addCheckpoint",
          "when": "view == checkpointXTree",
          "group": "navigation"
        },
        {
          "command": "checkpointX.clearAll",
          "when": "view == checkpointXTree",
          "group": "secondary"
        }
      ],
      "view/item/context": [
        {
          "command": "checkpointX.removeCheckpoint",
          "when": "view == checkpointXTree && viewItem == checkpoint",
          "group": "inline"
        }
      ]
    },
    "keybindings": [
      {
        "command": "checkpointX.addCheckpoint",
        "key": "ctrl+alt+p",
        "mac": "cmd+ctrl+p",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "CheckpointX",
      "properties": {
        "checkpointX.filename": {
          "type": "string",
          "default": "checkpoint.json",
          "description": "检查点数据存储文件名"
        },
        "checkpointX.showInExplorer": {
          "type": "boolean",
          "default": true,
          "description": "在资源管理器中显示 CheckpointX 侧边栏"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "16.x",
    "@types/vscode": "^1.74.0",
    "sharp": "^0.34.5",
    "typescript": "^4.9.4"
  }
}