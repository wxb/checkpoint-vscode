{
  "name": "checkpoint",
  "displayName": "Checkpoint - 代码检查点管理",
  "description": "在代码开发中实时记录需要上线前检查的事项，支持分支分类和团队协作",
  "version": "1.0.0",
  "publisher": "checkpoint",
  "author": {
    "name": "Checkpoint Team"
  },
  "license": "MIT",
  "homepage": "https://github.com/wxb/checkpoint-vscode#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/wxb/checkpoint-vscode"
  },
  "bugs": {
    "url": "https://github.com/wxb/checkpoint-vscode/issues"
  },
  "keywords": [
    "checkpoint",
    "code review",
    "todo",
    "git",
    "branch",
    "团队协作",
    "检查点",
    "代码审查"
  ],
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "icon": "images/icon.png",
  "activationEvents": [
    "onCommand:checkpoint.addCheckpoint"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "checkpoint.addCheckpoint",
        "title": "添加Checkpoint检查点",
        "category": "Checkpoint"
      },
      {
        "command": "checkpoint.removeCheckpoint",
        "title": "移除Checkpoint检查点",
        "category": "Checkpoint"
      },
      {
        "command": "checkpoint.viewCheckpoints",
        "title": "查看所有Checkpoint检查点",
        "category": "Checkpoint"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "checkpoint.addCheckpoint",
          "group": "9_cutcopypaste@5"
        }
      ]
    },
    "keybindings": [
      {
        "command": "checkpoint.addCheckpoint",
        "key": "ctrl+alt+p",
        "mac": "cmd+ctrl+p",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "Checkpoint",
      "properties": {
        "checkpoint.filename": {
          "type": "string",
          "default": "checkpoint.json",
          "description": "检查点数据存储文件名"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "16.x",
    "@types/vscode": "^1.74.0",
    "sharp": "^0.34.5",
    "typescript": "^4.9.4"
  }
}
